{
  "name": "brew-recipes",
  "version": "1.0.0",
  "private": true,
  "description": "Community pour-over coffee recipe database",
  "license": "CC0-1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "tsc --noEmit",
    "check:site": "node scripts/check-site.mjs",
    "validate": "node scripts/validate.mjs",
    "test": "npm run validate && npm run check && npm run build && npm run check:site",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm test"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "astro": "^7.0.3",
    "js-yaml": "^5.2.0",
    "three": "^0.185.1",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
