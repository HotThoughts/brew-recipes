---
// ASCII pour-over hero scene. Decorative, aria-hidden; content never depends on it.
---

<canvas class="ascii-hero" aria-hidden="true"></canvas>

<script>
  import { AsciiRenderer } from '../lib/ascii/renderer';
  import { heroScene } from '../lib/ascii/scenes';

  const canvases = document.querySelectorAll<HTMLCanvasElement>('.ascii-hero');
  canvases.forEach((canvas) => {
    if (window.matchMedia('(max-width: 700px)').matches) return;

    let renderer: AsciiRenderer | null = null;
    try {
      renderer = new AsciiRenderer(canvas, heroScene(), {
        cols: 80,
        rows: 80,
        fontSize: 8,
        fps: 20,
        fillContainer: true,
        transparentBackground: true,
      });
    } catch (err) {
      console.error('[ascii] Failed to initialize hero scene', err);
      return;
    }

    const r = renderer;

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) r.start();
          else r.stop();
        }
      },
      { threshold: 0.1 },
    );
    io.observe(canvas);

    const onVisibilityChange = () => {
      if (document.hidden) r.stop();
      else r.start();
    };
    document.addEventListener('visibilitychange', onVisibilityChange);

    const onPointerMove = (ev: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      // Guard: when the hero collapses to .compact the canvas is display:none
      // and getBoundingClientRect returns zero-area, producing NaN.
      if (rect.width === 0 || rect.height === 0) return;
      const nx = ((ev.clientX - rect.left) / rect.width) * 2 - 1;
      const ny = -(((ev.clientY - rect.top) / rect.height) * 2 - 1);
      r.pointer(nx, ny);
    };
    canvas.parentElement?.addEventListener('pointermove', onPointerMove);

    // Teardown on page unload.
    window.addEventListener('beforeunload', () => {
      document.removeEventListener('visibilitychange', onVisibilityChange);
      canvas.parentElement?.removeEventListener('pointermove', onPointerMove);
      io.disconnect();
      r.dispose();
    }, { once: true });
  });
</script>
