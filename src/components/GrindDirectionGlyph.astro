---
type Props = {
  direction: 'finer' | 'coarser';
};

const { direction } = Astro.props;
---

<svg
  class={`grind-direction-glyph grind-direction-glyph--${direction}`}
  viewBox="0 0 28 20"
  aria-hidden="true"
>
  {
    direction === 'finer' ? (
      <g fill="currentColor">
        <circle cx="7" cy="6" r="1.15" />
        <circle cx="12" cy="5" r="1.15" />
        <circle cx="17" cy="7" r="1.15" />
        <circle cx="21.5" cy="5.5" r="1.15" />
        <circle cx="8.5" cy="12" r="1.15" />
        <circle cx="14" cy="10.5" r="1.15" />
        <circle cx="19.5" cy="13" r="1.15" />
        <circle cx="13" cy="16" r="1.15" />
      </g>
    ) : (
      <g fill="currentColor">
        <circle cx="6.5" cy="11.5" r="3" />
        <circle cx="15" cy="7" r="3.8" />
        <circle cx="21.5" cy="14" r="3.25" />
      </g>
    )
  }
</svg>
