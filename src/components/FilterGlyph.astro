---
import type { PaperFilter } from '../lib/recipes';

interface Props {
  filter: PaperFilter;
}

const { filter } = Astro.props;
---

<svg
  class="filter-glyph"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {filter === 'cone' && (
    <path d="M4.5 7 Q12 1.5 19.5 7 L12 20 Z" />
  )}

  {filter === 'wave' && (
    <>
      <path d="M4.75 6 L6.2 17.3 Q6.5 19.5 12 19.5 Q17.5 19.5 17.8 17.3 L19.25 6" />
      <path d="M5.25 7.5 C6.1 8.35 6.95 8.35 7.8 7.5 C8.65 6.65 9.5 6.65 10.35 7.5 C11.2 8.35 12.05 8.35 12.9 7.5 C13.75 6.65 14.6 6.65 15.45 7.5 C16.3 8.35 17.15 8.35 18 7.5 C18.4 7.1 18.75 7.1 19 7.35" />
    </>
  )}
</svg>
