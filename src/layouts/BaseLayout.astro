---
import '../styles/global.css';
import AsciiAmbient from '../components/AsciiAmbient.astro';
import { withBase } from '../lib/recipes';

type Props = {
  title: string;
  description?: string;
  pageClass?: string;
};

const {
  title,
  description = 'Browse community-curated coffee recipes without reading raw YAML.',
  pageClass = '',
} = Astro.props;
const isGrinderPage = Astro.url.pathname.includes('/grinders');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e8e4f0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={pageClass}>
    <div class="texture-overlay" aria-hidden="true"></div>
    <AsciiAmbient />
    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav" aria-label="Primary">
          <a
            class="site-nav-link"
            href={withBase('/')}
            data-preserve-lang
            data-base-href={withBase('/')}
            aria-current={isGrinderPage ? undefined : 'page'}
          >
            <span class="lang-en">Recipes</span>
            <span class="lang-zh">配方</span>
          </a>
          <a
            class="site-nav-link"
            href={withBase('/grinders/')}
            data-preserve-lang
            data-base-href={withBase('/grinders/')}
            data-site-grinders-link
            aria-current={isGrinderPage ? 'page' : undefined}
          >
            <span class="lang-en">Grinders</span>
            <span class="lang-zh">研磨器</span>
          </a>
          <a href="https://github.com/HotThoughts/brew-recipes">GitHub</a>
          <span class="lang-switch" aria-label="Language">
            <a href="#en" class="lang-opt" data-lang="en">en</a>
            <span class="lang-sep">/</span>
            <a href="#zh" class="lang-opt" data-lang="zh">zh</a>
          </span>
        </nav>
      </header>

      <slot />
    </div>
  </body>
</html>

<script>
  const validLangs = ['en', 'zh'];

  function applyLang() {
    const [hashLang, hashAnchor] = window.location.hash.slice(1).split(':', 2);
    const lang = validLangs.includes(hashLang) ? hashLang : 'en';

    // Update body class for CSS-based language toggling
    document.body.classList.remove('lang-en', 'lang-zh');
    document.body.classList.add(`lang-${lang}`);

    // Update html lang attribute
    document.documentElement.lang = lang;

    // Highlight active language in the header switch
    document.querySelectorAll('.lang-opt').forEach((el) => {
      el.classList.toggle('active', el.dataset.lang === lang);
      const anchor = hashAnchor ? `:${hashAnchor}` : '';
      el.setAttribute('href', `#${el.dataset.lang}${anchor}`);
    });

    // Keep internal guide links in the user's active language.
    document.querySelectorAll('a[data-preserve-lang]').forEach((el) => {
      const anchor = el as HTMLAnchorElement;
      const baseHref = anchor.dataset.baseHref ?? anchor.getAttribute('href') ?? '';
      const targetAnchor = anchor.dataset.anchor ? `:${anchor.dataset.anchor}` : '';
      anchor.href = `${baseHref}#${lang}${targetAnchor}`;
    });

    // Notify decorative layers (ASCII canvases) so they can start/stop
    // renderers whose visibility depends on the active language.
    window.dispatchEvent(new CustomEvent('langchange'));
  }

  applyLang();
  window.addEventListener('hashchange', applyLang);
</script>
