---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterGlyph from '../../components/FilterGlyph.astro';
import PourGlyph from '../../components/PourGlyph.astro';
import { t } from '../../lib/i18n';
import { getGrinder, getGrinderRangeForBrewer } from '../../lib/grinders';
import {
  formatBrewerName,
  formatBrewTemperature,
  formatSeconds,
  getPourStyles,
  getRecipeCollection,
  getTotalPhaseWater,
  getTotalWaitSeconds,
  type Recipe,
  withBase,
} from '../../lib/recipes';

export function getStaticPaths() {
  const collection = getRecipeCollection();
  const seen = new Set<string>();

  return collection.recipes
    .filter((r) => {
      if (seen.has(r.id)) return false;
      seen.add(r.id);
      return true;
    })
    .map((recipe) => ({
      params: { brewer: recipe.brewerSlug, id: recipe.id },
      props: {
        enRecipe:
          collection.byLanguage.get('en')?.find((r) => r.id === recipe.id) ?? null,
        zhRecipe:
          collection.byLanguage.get('zh')?.find((r) => r.id === recipe.id) ?? null,
      },
    }));
}

const { enRecipe, zhRecipe } = Astro.props as {
  enRecipe: Recipe | null;
  zhRecipe: Recipe | null;
};
const mainRecipe = enRecipe ?? zhRecipe;
if (!mainRecipe) return Astro.redirect('/');
const allTags = [
  ...new Set([...(enRecipe?.tags ?? []), ...(zhRecipe?.tags ?? [])]),
];
const isColdBrew = mainRecipe.brewer === 'ColdBrew';
const featuredGrinder = getGrinder('comandante-c40-mk4');
const grinderRange = featuredGrinder
  ? getGrinderRangeForBrewer(featuredGrinder, mainRecipe.brewer)
  : undefined;

function rangeText(language: 'en' | 'zh'): string {
  if (!grinderRange) return '';
  if (grinderRange.min_clicks !== undefined && grinderRange.max_clicks !== undefined) {
    return `${grinderRange.min_clicks}–${grinderRange.max_clicks} ${t[language].grinders.units.clicks}`;
  }
  return t[language].grinders.guidance.recipeDependent;
}
---

<BaseLayout title={`${mainRecipe.name} | ${t.en.site.title} | ${t.zh.site.title}`} pageClass="detail-page">
  <main class="recipe-detail">
    <article class="recipe-article">
      {
        enRecipe && (
          <div class="recipe-version lang-en">
            <header class="recipe-header">
              <div>
                <p class="system-line">{formatBrewerName(enRecipe.brewer)} / {enRecipe.id}</p>
                <h1 class="page-title">{enRecipe.name}</h1>
              </div>
            </header>

            {enRecipe.description && <p class="recipe-intro">{enRecipe.description}</p>}

            {allTags.length > 0 && (
              <ul class="tag-list" aria-label="Tags">
                {allTags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}

            <section class="spec-grid" aria-label="Recipe specs">
              <div><span class="label">{t.en.detail.spec.dose}</span><strong>{enRecipe.dose_g}g</strong></div>
              <div><span class="label">{t.en.detail.spec.water}</span><strong>{enRecipe.water_ml}ml</strong></div>
              <div><span class="label">{t.en.detail.spec.ratio}</span><strong>{enRecipe.ratio ?? 'n/a'}</strong></div>
              <div><span class="label">{isColdBrew ? t.en.detail.spec.brewTemperature : t.en.detail.spec.temperature}</span><strong>{formatBrewTemperature(enRecipe, 'en')}</strong></div>
              <div>
                <span class="label">{t.en.detail.spec.grind}</span>
                <strong>{enRecipe.grind_size}</strong>
                {grinderRange && <a
                  class="grinder-spec-link"
                  href={withBase(featuredGrinder!.urlPath)}
                  data-preserve-lang
                  data-base-href={withBase(featuredGrinder!.urlPath)}
                  data-anchor={grinderRange.id}
                >C40 · {rangeText('en')} →</a>}
              </div>
              <div><span class="label">{isColdBrew ? t.en.detail.spec.brewTime : t.en.detail.spec.wait}</span><strong>{formatSeconds(getTotalWaitSeconds(enRecipe), 'en')}</strong></div>
              {enRecipe.paper_filter && <div><span class="label">{t.en.detail.spec.paperFilter}</span><strong class="filter-value"><FilterGlyph filter={enRecipe.paper_filter} /><span>{t.en.detail.spec[enRecipe.paper_filter]}</span></strong></div>}
            </section>

            <section class="phase-section" aria-labelledby="phase-title-en">
              <div class="section-heading compact">
                <h2 id="phase-title-en">{isColdBrew ? t.en.detail.brewSteps : t.en.detail.phases}</h2>
                <p>{(isColdBrew ? t.en.detail.brewStepSummary : t.en.detail.phaseSummary)
                  .replace('{water}', String(enRecipe.phases.reduce((t, p) => t + getTotalPhaseWater(p), 0)))
                  .replace('{time}', formatSeconds(getTotalWaitSeconds(enRecipe), 'en'))
                  .replace('{count}', String(enRecipe.phases.length))}</p>
                {!isColdBrew && <a
                  class="phase-guide-link"
                  href={withBase('/pour-styles/')}
                  data-preserve-lang
                  data-base-href={withBase('/pour-styles/')}
                >{t.en.detail.pourGuideLink}</a>}
              </div>
              <ol class="phase-list">
                {enRecipe.phases.map((phase, i) => {
                  const pourStyles = getPourStyles(phase.note);
                  return (
                    <li class="phase-row">
                      <span class="phase-index">{String(i + 1).padStart(2, '0')}</span>
                      <div class="phase-copy">
                        <h3>{phase.label}</h3>
                        {!isColdBrew && pourStyles.length > 0 && (
                          <ul class="pour-styles" aria-label={t.en.detail.pour.label}>
                            {pourStyles.map((pourStyle) => (
                              <li>
                                <PourGlyph style={pourStyle} />
                                <span>{t.en.detail.pour[pourStyle]}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                        {phase.note && <p>{phase.note}</p>}
                      </div>
                      <div class="phase-values">
                        {(!isColdBrew || phase.water_g > 0) && <span>{phase.water_g}g{phase.pours ? ` × ${phase.pours}` : ''}</span>}
                        {(!isColdBrew || phase.wait_seconds !== undefined) && <span>{formatSeconds(phase.wait_seconds, 'en')}</span>}
                      </div>
                    </li>
                  );
                })}
              </ol>
            </section>

            <footer class="source-panel">
              <div>
                <span class="label">{t.en.detail.source}</span>
                <strong>{enRecipe.source.name}</strong>
                {enRecipe.source.competition && <span>{enRecipe.source.competition}</span>}
              </div>
              {enRecipe.source.url && <a href={enRecipe.source.url}>{t.en.detail.sourceLink}</a>}
            </footer>
          </div>
        )
      }

      {
        zhRecipe && (
          <div class="recipe-version lang-zh">
            <header class="recipe-header">
              <div>
                <p class="system-line">{formatBrewerName(zhRecipe.brewer)} / {zhRecipe.id}</p>
                <h1 class="page-title">{zhRecipe.name}</h1>
              </div>
            </header>

            {zhRecipe.description && <p class="recipe-intro">{zhRecipe.description}</p>}

            {allTags.length > 0 && (
              <ul class="tag-list" aria-label="Tags">
                {allTags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}

            <section class="spec-grid" aria-label="Recipe specs">
              <div><span class="label">{t.zh.detail.spec.dose}</span><strong>{zhRecipe.dose_g}g</strong></div>
              <div><span class="label">{t.zh.detail.spec.water}</span><strong>{zhRecipe.water_ml}ml</strong></div>
              <div><span class="label">{t.zh.detail.spec.ratio}</span><strong>{zhRecipe.ratio ?? '无'}</strong></div>
              <div><span class="label">{isColdBrew ? t.zh.detail.spec.brewTemperature : t.zh.detail.spec.temperature}</span><strong>{formatBrewTemperature(zhRecipe, 'zh')}</strong></div>
              <div>
                <span class="label">{t.zh.detail.spec.grind}</span>
                <strong>{zhRecipe.grind_size}</strong>
                {grinderRange && <a
                  class="grinder-spec-link"
                  href={withBase(featuredGrinder!.urlPath)}
                  data-preserve-lang
                  data-base-href={withBase(featuredGrinder!.urlPath)}
                  data-anchor={grinderRange.id}
                >C40 · {rangeText('zh')} →</a>}
              </div>
              <div><span class="label">{isColdBrew ? t.zh.detail.spec.brewTime : t.zh.detail.spec.wait}</span><strong>{formatSeconds(getTotalWaitSeconds(zhRecipe), 'zh')}</strong></div>
              {zhRecipe.paper_filter && <div><span class="label">{t.zh.detail.spec.paperFilter}</span><strong class="filter-value"><FilterGlyph filter={zhRecipe.paper_filter} /><span>{t.zh.detail.spec[zhRecipe.paper_filter]}</span></strong></div>}
            </section>

            <section class="phase-section" aria-labelledby="phase-title-zh">
              <div class="section-heading compact">
                <h2 id="phase-title-zh">{isColdBrew ? t.zh.detail.brewSteps : t.zh.detail.phases}</h2>
                <p>{(isColdBrew ? t.zh.detail.brewStepSummary : t.zh.detail.phaseSummary)
                  .replace('{water}', String(zhRecipe.phases.reduce((t, p) => t + getTotalPhaseWater(p), 0)))
                  .replace('{time}', formatSeconds(getTotalWaitSeconds(zhRecipe), 'zh'))
                  .replace('{count}', String(zhRecipe.phases.length))}</p>
                {!isColdBrew && <a
                  class="phase-guide-link"
                  href={withBase('/pour-styles/')}
                  data-preserve-lang
                  data-base-href={withBase('/pour-styles/')}
                >{t.zh.detail.pourGuideLink}</a>}
              </div>
              <ol class="phase-list">
                {zhRecipe.phases.map((phase, i) => {
                  const pourStyles = getPourStyles(phase.note);
                  return (
                    <li class="phase-row">
                      <span class="phase-index">{String(i + 1).padStart(2, '0')}</span>
                      <div class="phase-copy">
                        <h3>{phase.label}</h3>
                        {!isColdBrew && pourStyles.length > 0 && (
                          <ul class="pour-styles" aria-label={t.zh.detail.pour.label}>
                            {pourStyles.map((pourStyle) => (
                              <li>
                                <PourGlyph style={pourStyle} />
                                <span>{t.zh.detail.pour[pourStyle]}</span>
                              </li>
                            ))}
                          </ul>
                        )}
                        {phase.note && <p>{phase.note}</p>}
                      </div>
                      <div class="phase-values">
                        {(!isColdBrew || phase.water_g > 0) && <span>{phase.water_g}g{phase.pours ? ` × ${phase.pours}` : ''}</span>}
                        {(!isColdBrew || phase.wait_seconds !== undefined) && <span>{formatSeconds(phase.wait_seconds, 'zh')}</span>}
                      </div>
                    </li>
                  );
                })}
              </ol>
            </section>

            <footer class="source-panel">
              <div>
                <span class="label">{t.zh.detail.source}</span>
                <strong>{zhRecipe.source.name}</strong>
                {zhRecipe.source.competition && <span>{zhRecipe.source.competition}</span>}
              </div>
              {zhRecipe.source.url && <a href={zhRecipe.source.url}>{t.zh.detail.sourceLink}</a>}
            </footer>
          </div>
        )
      }

      <nav class="detail-nav" aria-label="Recipe navigation">
        <a href={withBase(`/#${mainRecipe.brewerSlug}`)}>
          <span class="lang-en">← {formatBrewerName(mainRecipe.brewer)} {t.en.detail.breadcrumbMethods}</span>
          <span class="lang-zh">← {formatBrewerName(mainRecipe.brewer)} {t.zh.detail.breadcrumbMethods}</span>
        </a>
      </nav>
    </article>
  </main>
</BaseLayout>
